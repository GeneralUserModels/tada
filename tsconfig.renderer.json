{
  "compilerOptions": {
    "composite": true,
    "outDir": "dist/renderer",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/client/renderer/**/*", "src/client/shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
