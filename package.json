{
  "name": "powernap",
  "version": "0.0.1-alpha",
  "description": "PowerNap — predict what you'll do next",
  "author": "PowerNap",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && DOTENV_CONFIG_PATH=.env electron -r dotenv/config dist/main/index.js",
    "dev": "npm run build && DOTENV_CONFIG_PATH=.env electron -r dotenv/config dist/main/index.js",
    "dist": "npm run build && npx electron-builder --mac --publish never",
    "release": "npm run build && npx electron-builder --mac --publish always",
    "reset": "rm -f .onboarding-complete powernap-config.json ~/.config/powernap/server-config.json"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.powernap.app",
    "productName": "PowerNap",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "identity": null,
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "PowerNap needs screen recording to observe your workflow.",
        "NSAccessibilityUsageDescription": "PowerNap needs accessibility access to track input events."
      }
    },
    "extraResources": [
      {
        "from": "./src/powernap",
        "to": "python-src/powernap"
      },
      {
        "from": "./src/connectors",
        "to": "python-src/connectors"
      },
      {
        "from": "./bootstrap/requirements.txt",
        "to": "python-src/requirements.txt"
      },
      {
        "from": "./pyproject.toml",
        "to": "python-src/pyproject.toml"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "GeneralUserModels",
      "repo": "powernap-release"
    },
    "dmg": {
      "title": "PowerNap",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
