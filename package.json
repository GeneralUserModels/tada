{
  "name": "tada",
  "version": "0.0.3-alpha",
  "description": "Tada — predict what you'll do next",
  "author": "Tada",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron dist/main/index.js",
    "dev": "node scripts/dev-supervisor.cjs",
    "dist": "npm run build && npx electron-builder --mac --publish never",
    "release": "npm run build && REQUIRE_NOTARIZATION=1 npx electron-builder --mac --publish never",
    "release:publish": "npm run build && REQUIRE_NOTARIZATION=1 npx electron-builder --mac --publish always",
    "reset": "rm -f tada-config.json ~/.config/tada/google-token.json ~/.config/tada/outlook-token.json"
  },
  "dependencies": {
    "eventsource": "^3.0.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.0.0",
    "@types/eventsource": "^1.1.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^17.4.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.tada.app",
    "productName": "Tada",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "src/client/build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Tada needs screen recording to observe your workflow.",
        "NSAccessibilityUsageDescription": "Tada needs accessibility access to track input events."
      }
    },
    "extraResources": [
      {
        "from": "./src/server",
        "to": "python-src/server"
      },
      {
        "from": "./src/connectors",
        "to": "python-src/connectors"
      },
      {
        "from": "./src/user_models",
        "to": "python-src/user_models"
      },
      {
        "from": "./src/apps",
        "to": "python-src/apps"
      },
      {
        "from": "./src/agent",
        "to": "python-src/agent"
      },
      {
        "from": "./src/retrievers",
        "to": "python-src/retrievers"
      },
      {
        "from": "./bootstrap/requirements.txt",
        "to": "python-src/requirements.txt"
      },
      {
        "from": "./pyproject.toml",
        "to": "python-src/pyproject.toml"
      },
      {
        "from": "./tada-config.defaults.json",
        "to": "tada-config.defaults.json"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "GeneralUserModels",
      "repo": "tada"
    },
    "dmg": {
      "title": "Tada",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
