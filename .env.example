# Gemini API key for litellm (labeling & reward model)
GEMINI_API_KEY=

# Tinker API key for OAI inference endpoint
TINKER_API_KEY=

# Huggingface token
HF_TOKEN=

# (Optional) Weights & Biases API key for logging
WANDB_API_KEY=

# (Optional) Override the default tinker model
# POWERNAP_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# Google OAuth credentials (for Electron client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase credentials (for Electron client)
SUPABASE_URL=
SUPABASE_ANON_KEY=
